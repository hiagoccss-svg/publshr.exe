{
  "name": "@publshr/spaces",
  "version": "0.1.0",
  "description": "Publshr Spaces — enterprise operations & project management",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev:web": "vite --config vite.config.ts",
    "build:web": "vite build --config vite.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dev": "npm run tauri:dev",
    "dev:electron": "electron-vite dev",
    "build": "npm run build:web",
    "build:electron": "electron-vite build",
    "dist": "npm run tauri:build",
    "dist:electron": "npm run build:electron && electron-builder --config electron-builder.yml",
    "dist:shell": "npm run build:electron && electron-builder --config electron-builder.yml --publish never",
    "preview": "vite preview --config vite.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.node.json",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/supabase-js": "^2.49.1",
    "better-sqlite3": "^11.8.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.475.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "uuid": "^11.1.0",
    "zustand": "^5.0.3",
    "electron-updater": "^6.3.9",
    "tldraw": "^3.10.0",
    "@tauri-apps/api": "^2.11.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^6.2.0"
  }
}
