{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "composite": true,
    "noEmit": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "electron-updater": ["node_modules/electron-updater"]
    }
  },
  "include": [
    "src/main/**/*",
    "src/shared/**/*",
    "electron.vite.config.ts",
    "../../shared/electron/**/*.ts"
  ]
}
